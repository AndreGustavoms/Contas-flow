# --- Login local do app (cofre Contas_exe) ---
# Credenciais de acesso ao app. NUNCA preencha com valores reais aqui:
# este arquivo (.env.example) VAI para o repositorio publico.
# Copie para ".env" e defina os valores reais la (o ".env" e ignorado pelo git).
VITE_LOCAL_LOGIN_NAME=
VITE_LOCAL_LOGIN_PASSWORD=

# --- Protecao do servidor em PRODUCAO (Basic Auth) ---
# Esta e a protecao REAL: o login do front (VITE_*) e embutido no bundle do
# navegador e nao protege a API. Quando estes dois valores estao definidos, o
# servidor exige usuario/senha (Basic Auth) em TODA requisicao (API + UI).
# Defina-os como variaveis de ambiente no host (ex.: Railway), NUNCA no repo.
APP_AUTH_USER=
APP_AUTH_PASSWORD=

# Diretorio de armazenamento persistente. Em producao aponte para um volume
# que sobreviva a restart/deploy (ex.: /data no Railway). Em branco = ./storage.
CONTAS_FLOW_STORAGE_DIR=

# --- YouTube Data API (OAuth 2.0) ---
# Copie este arquivo para ".env" e preencha com os valores do Google Cloud.
# O ".env" NUNCA vai para o git (veja .gitignore).

# Client ID e Client Secret gerados em:
# Google Cloud Console > APIs e Serviços > Credenciais > ID do cliente OAuth (tipo "App da Web")
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# Precisa bater EXATAMENTE com um dos "URIs de redirecionamento autorizados"
# cadastrados no mesmo ID do cliente OAuth.
# Local (Fase 0): http://127.0.0.1:8787/api/youtube/callback
# Produção (depois): https://SEU-DOMINIO/api/youtube/callback
YOUTUBE_REDIRECT_URI=http://127.0.0.1:8787/api/youtube/callback
